# -----------------------------------------------------------------------------
# PostgreSQL — local install (default dev)
# -----------------------------------------------------------------------------
# Run Postgres on the host (e.g. port 5432). Create DB and a user the app can use, for example:
#   createuser urlshortener
#   createdb -O urlshortener urlshortener
#   psql -d urlshortener -c "ALTER USER urlshortener WITH PASSWORD 'yourpassword';"
# Then set DB_* below to match. Flyway runs migrations on startup.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=urlshortener
DB_USER=urlshortener
DB_PASSWORD=urlshortener

# When Spring Boot runs inside Docker (`docker compose --profile full`), Compose sets
# DB_HOST=host.docker.internal so the container can reach your host Postgres. Override if needed
# (e.g. Linux: bridge IP or ensure host.docker.internal is defined).

# -----------------------------------------------------------------------------
# Redis — `docker compose up -d redis` exposes 6379 on localhost
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_TTL=24h

# Backend — base URL used when building short links in API responses (no trailing slash)
PUBLIC_SHORT_LINK_BASE=http://localhost:8080

# CORS — comma-separated origins for the Next.js dev server
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend — Spring Boot API base (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Docker Compose optional port overrides (profile `full`)
BACKEND_PORT=8080
FRONTEND_PORT=3000
